generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== TENANT ====================
model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique

  // GHL Connection
  ghlLocationId   String?   @unique
  ghlAccessToken  String?   // AES-256-GCM encrypted
  ghlRefreshToken String?   // AES-256-GCM encrypted
  ghlTokenExpiry  DateTime?
  ghlConnectedAt  DateTime?
  ghlAppId        String?   // Marketplace app ID

  // Onboarding
  onboardingComplete Boolean @default(false)

  // Data mode
  dataMode        String    @default("mock") // "mock" or "live"

  // Demo tenant flag
  isDemo          Boolean   @default(false)

  // Onboarding steps (for real tenants)
  onboardingStep1 Boolean   @default(false) // Has products
  onboardingStep2 Boolean   @default(false) // Has quotes
  onboardingStep3 Boolean   @default(false) // Has reservations
  onboardingDismissed Boolean @default(false)

  // Sync progress (shown in UI during full sync)
  syncState       String?   // "syncing" | "complete" | "error" | null
  syncProgressMsg String?   // "Contactos: 2400/5000"
  lastSyncAt      DateTime?
  lastSyncError   String?

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users              User[]
  roles              Role[]
  moduleConfigs      ModuleConfig[]
  notifications      Notification[]
  products           Product[]
  quotes             Quote[]
  reservations       Reservation[]
  stationCapacity    StationCapacity[]
  grouponMappings    GrouponProductMapping[]
  tasks              Task[]
  cachedContacts     CachedContact[]
  cachedConversations CachedConversation[]
  cachedOpportunities CachedOpportunity[]
  cachedPipelines    CachedPipeline[]
  syncStatus         SyncStatus?
  seasonCalendar     SeasonCalendar[]

  // Catalog Extensions
  categories            Category[]
  locations             Location[]
  experienceVariants    ExperienceVariant[]
  productTimeSlots      ProductTimeSlot[]

  // Hotel
  roomTypes             RoomType[]
  roomRateSeasons       RoomRateSeason[]
  roomRates             RoomRate[]
  roomBlocks            RoomBlock[]
  lodgeStays            LodgeStay[]

  // Restaurant
  restaurants            Restaurant[]
  restaurantShifts       RestaurantShift[]
  restaurantClosures     RestaurantClosure[]
  restaurantBookings     RestaurantBooking[]
  restaurantStaff        RestaurantStaff[]
  dailyMenus             DailyMenu[]
  restaurantReservations RestaurantReservation[]

  // Spa
  spaCategories         SpaCategory[]
  spaTreatments         SpaTreatment[]
  spaResources          SpaResource[]
  spaSlots              SpaSlot[]
  spaScheduleTemplates  SpaScheduleTemplate[]

  // Booking/Operations
  clients               Client[]
  activityBookings      ActivityBooking[]
  bookingMonitors       BookingMonitor[]
  dailyOrders           DailyOrder[]

  // Finance
  invoices              Invoice[]
  invoiceLines          InvoiceLine[]
  transactions          Transaction[]
  costCenters           CostCenter[]
  expenseCategories     ExpenseCategory[]
  expenses              Expense[]
  expenseFiles          ExpenseFile[]
  recurringExpenses     RecurringExpense[]

  // Suppliers
  suppliers             Supplier[]
  supplierSettlements   SupplierSettlement[]
  settlementLines       SettlementLine[]
  settlementDocuments   SettlementDocument[]
  settlementStatusLogs  SettlementStatusLog[]

  // REAV
  reavExpedients        ReavExpedient[]
  reavCosts             ReavCost[]
  reavDocuments         ReavDocument[]

  // TPV
  cashRegisters         CashRegister[]
  cashSessions          CashSession[]
  cashMovements         CashMovement[]
  tpvSales              TpvSale[]
  tpvSaleItems          TpvSaleItem[]

  // Storefront & Promotions
  discountCodes         DiscountCode[]
  discountCodeUses      DiscountCodeUse[]
  compensationVouchers  CompensationVoucher[]

  // CMS
  siteSettings          SiteSetting[]
  slideshowItems        SlideshowItem[]
  cmsMenuItems          CmsMenuItem[]
  staticPages           StaticPage[]
  pageBlocks            PageBlock[]
  galleryItems          GalleryItem[]
  mediaFiles            MediaFile[]
  homeModuleItems       HomeModuleItem[]

  // Ticketing & Platforms
  externalPlatforms     ExternalPlatform[]
  platformProducts      PlatformProduct[]
  couponRedemptions     CouponRedemption[]
  couponEmailConfigs    CouponEmailConfig[]

  // Reviews
  reviews               Review[]

  // Packs
  legoPacks             LegoPack[]
  legoPackLines         LegoPackLine[]

  // Cancellations
  cancellationRequests  CancellationRequest[]
  cancellationLogs      CancellationLog[]

  // Payroll
  payrollRecords        PayrollRecord[]
  payrollExtras         PayrollExtra[]

  // Instructors
  instructors              Instructor[]
  instructorAvailability   InstructorAvailability[]
  instructorTimeEntries    InstructorTimeEntry[]
  instructorAssignments    InstructorAssignment[]

  // Rental
  rentalInventory          RentalInventory[]
  rentalOrders             RentalOrder[]
  customerSizingProfiles   CustomerSizingProfile[]

  // Planning Engine
  planningParticipants     Participant[]
  operationalUnits         OperationalUnit[]
  groupCells               GroupCell[]
  classCheckIns            ClassCheckIn[]
  planningIncidents        Incident[]
  freeDayRequests          FreeDayRequest[]

  // Diplomas, Disciplinary, Notifications
  diplomas                 Diploma[]
  disciplinaryRecords      DisciplinaryRecord[]
  notificationTemplates    NotificationTemplate[]
  notificationLogs         NotificationLog[]

  // Document Numbering
  documentCounters         DocumentCounter[]
  documentNumberLogs       DocumentNumberLog[]

  // Email & PDF Templates
  emailTemplates           EmailTemplate[]
  pdfTemplates             PdfTemplate[]

  // Leads
  leads                    Lead[]

  // CRM
  crmActivityLogs          CrmActivityLog[]
  pendingPayments          PendingPayment[]

  // Lego Packs
  legoPackSnapshots        LegoPackSnapshot[]

  // Internal chat
  messages                 Message[]
}

// ==================== USER ====================
model User {
  id            String    @id @default(cuid())
  email         String
  name          String?
  passwordHash  String?
  avatarUrl     String?
  tenantId      String
  roleId        String
  ghlUserId     String?   // Maps to GHL user ID
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  inviteToken   String?   @unique
  inviteExpires DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role          Role      @relation(fields: [roleId], references: [id])
  notifications Notification[]
  restaurantStaff  RestaurantStaff[]
  bookingMonitors  BookingMonitor[]
  cashSessions     CashSession[]
  payrollRecords   PayrollRecord[]
  instructor       Instructor?
  leads            Lead[]
  messagesSent     Message[] @relation("MessageFromUser")
  messagesReceived Message[] @relation("MessageToUser")

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([ghlUserId])
}

// ==================== RBAC ====================
model Role {
  id          String   @id @default(cuid())
  name        String
  tenantId    String
  isSystem    Boolean  @default(false)  // System roles can't be deleted
  permissions Json     // String array of permission keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

// ==================== MODULE CONFIG ====================
model ModuleConfig {
  id          String   @id @default(cuid())
  tenantId    String
  module      String   // "comms", "pipelines", "analytics", "contacts"
  isEnabled   Boolean  @default(true)
  config      Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
}

// ==================== NOTIFICATIONS ====================
model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String   // Target user
  type        String   // "new_message", "deal_moved", "contact_created", etc.
  title       String
  body        String?
  data        Json?    // Arbitrary payload (contactId, conversationId, etc.)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId, createdAt])
}

// ==================== INTERNAL CHAT ====================
model Message {
  id          String   @id @default(cuid())
  tenantId    String
  fromUserId  String
  toUserId    String
  body        String
  isRead      Boolean  @default(false)
  readAt      DateTime?
  createdAt   DateTime @default(now())

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fromUser User   @relation("MessageFromUser", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User   @relation("MessageToUser",   fields: [toUserId],   references: [id], onDelete: Cascade)

  @@index([tenantId, toUserId, isRead])
  @@index([tenantId, fromUserId, createdAt])
  @@index([toUserId, createdAt])
}

// ==================== PRODUCT CATALOG ====================
model Product {
  id             String   @id @default(cuid())
  tenantId       String?  // null = global catalog (shared across all tenants)
  category       String   // "alquiler", "escuela", "clase_particular", "forfait", "locker", "apreski"
  name           String
  station        String   // "baqueira", "sierra_nevada", "valdesqui", "la_pinilla", "grandvalira", "formigal", "alto_campoo", "all"
  description    String?
  personType     String?  // "adulto", "infantil", "baby", null
  tier           String?  // "media_quality", "alta_quality", null (for equipment tiers)
  includesHelmet Boolean  @default(false)
  priceType      String   // "per_day", "per_person_per_hour", "per_session", "fixed"
  price          Float    @default(0) // Base price (1 day, media season) for display
  pricingMatrix  Json?    // Season-aware pricing: { media: {...}, alta: {...} }
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  supplierId     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // PORT-04: Catalog enrichment (ported from Nayade experiences)
  slug                      String?   // Unique per tenant for public URLs
  fiscalRegime              String    @default("general") // "general" | "reav" | "mixed"
  productType               String?   // "experiencia" | "actividad" | "transporte" | "alojamiento" | "restauracion" | "pack" | "alquiler" | "otro"
  providerPercent           Float?    // Provider margin percentage (0-100)
  agencyMarginPercent       Float?    // Agency margin percentage (0-100)
  supplierCommissionPercent Float?    // Supplier commission percentage (0-100)
  supplierCostType          String?   // "percentage" | "fixed" | "margin" | "hybrid"
  settlementFrequency       String?   // "biweekly" | "monthly" | "quarterly"
  isSettlable               Boolean   @default(false)
  isFeatured                Boolean   @default(false)
  isPublished               Boolean   @default(true)
  isPresentialSale          Boolean   @default(false)
  discountPercent           Float?    // Discount percentage (0-100)
  discountExpiresAt         DateTime?
  coverImageUrl             String?
  images                    Json      @default("[]") // Gallery array of image URLs
  includes                  Json?     // ["Seguro", "Material"] — what's included
  excludes                  Json?     // ["Transporte"] — what's not included
  metaTitle                 String?   // SEO title
  metaDescription           String?   // SEO description
  difficulty                String?   // "facil" | "intermedio" | "avanzado" | "experto"

  // Planning fields
  discipline          String?  // "esqui" | "snow" | "telemark" | "freestyle"
  minAge              Int?
  maxAge              Int?
  maxParticipants     Int?
  requiresGrouping    Boolean  @default(false)
  planningMode        String?  // "fixed_slot" | "dynamic_grouping"
  defaultMeetingPointId String?

  tenant           Tenant?             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier         Supplier?           @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  quoteItems       QuoteItem[]
  variants         ExperienceVariant[]
  timeSlots        ProductTimeSlot[]
  platformProducts  PlatformProduct[]
  operationalUnits  OperationalUnit[]
  couponRedemptions CouponRedemption[]

  @@unique([tenantId, slug])
  @@index([station, category])
  @@index([category])
  @@index([tenantId, isPublished])
}

// ==================== SEASON CALENDAR ====================
model SeasonCalendar {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  station   String   // "baqueira", "sierra_nevada", etc. or "all"
  season    String   // "media" or "alta"
  startDate DateTime
  endDate   DateTime
  label     String?  // "Navidades", "Semana Santa", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, station])
  @@unique([tenantId, station, startDate])
}

// ==================== QUOTES (PRESUPUESTOS) ====================
model Quote {
  id              String    @id @default(cuid())
  tenantId        String
  number          String?   // Sequential "PRE-2026-0001" via generateDocumentNumber()
  leadId          String?   // FK to Lead (a lead can have multiple quote revisions)
  agentId         String?   // Sales agent (User.id) who created/owns the quote
  ghlContactId    String?   // GHL contact ID
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientNotes     String?

  // Request data (from form)
  destination     String    // baqueira, sierra_nevada, formigal, alto_campoo, grandvalira
  checkIn         DateTime
  checkOut        DateTime
  adults          Int       @default(2)
  children        Int       @default(0)
  wantsAccommodation Boolean @default(false)
  wantsForfait    Boolean   @default(false)
  wantsClases     Boolean   @default(false)
  wantsEquipment  Boolean   @default(false)

  // Quote state
  status          String    @default("nuevo") // nuevo, borrador, enviado, pagado, expirado, cancelado
  totalAmount     Float     @default(0)
  expiresAt       DateTime?
  sentAt          DateTime?

  // Payment (Redsys)
  redsysOrderId    String?   @unique  // Ds_Order (12 chars, unique per payment)
  redsysPaymentUrl String?             // Generated Redsys payment URL
  paymentMethod    String?             // "redsys" | "transfer" | "cash"
  paymentStatus    String?   @default("pending") // "pending" | "paid" | "failed"
  paidAt           DateTime?
  paymentRef       String?             // Redsys auth code or transfer ref

  // PDF
  pdfUrl           String?             // URL/path to generated PDF

  // Email tracking
  emailSentAt      DateTime?           // When quote email was sent
  emailSentTo      String?             // Email address sent to
  reminderSentAt   DateTime?           // When last reminder was sent
  reminderCount    Int       @default(0)
  lastReminderStep String?             // "reminder_1" | "reminder_2" | "discount" | "expiry_warning" | "expired"

  // Post-payment follow-up tracking
  crossSellSentAt  DateTime?           // When cross-sell email was sent
  reviewSentAt     DateTime?           // When review request was sent
  preTripStep      String?             // "pre_48h" | "pre_24h" | "day_of"

  // GHL link
  ghlOpportunityId String?             // Link to GHL opportunity
  ghlPipelineId    String?             // Pipeline the opp is in
  ghlStageId       String?             // Current stage ID

  // Internal
  source           String?             // "manual" | "survey" (auto-created from GHL webhook)
  internalNotes    String?
  createdBy        String?             // User ID who created

  // Cancellation
  cancelledAt      DateTime?
  cancelReason     String?             // "cliente_solicita" | "sin_disponibilidad" | "error_presupuesto" | "otro"
  cancelType       String?             // "bono" | "devolucion" | "sin_devolucion" | "groupon"
  cancelNotes      String?             // Free text for "otro"
  refundIban       String?
  refundTitular    String?
  refundStatus     String?             // "pendiente" | "completado"
  bonoCode         String?             // Generated voucher code
  bonoAmount       Float?
  bonoExpiresAt    DateTime?

  // Public payment link — token-based URL for clients to view & pay without login
  paymentLinkToken     String?   @unique
  paymentLinkUrl       String?

  // Bank transfer flow — admin uploads/validates the transfer proof
  transferProofUrl     String?
  transferConfirmedAt  DateTime?
  transferConfirmedBy  String?  // userId who validated the transfer

  // Origin marker — true when generated automatically (e.g. from GHL Survey)
  isAutoGenerated      Boolean  @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lead            Lead?     @relation("LeadQuotes", fields: [leadId], references: [id], onDelete: SetNull)
  items           QuoteItem[]
  reservations    Reservation[]
  tasks           Task[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@index([tenantId, leadId])
  @@index([tenantId, agentId])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  name        String   // Snapshot of product name
  description String?
  category    String?  // Product category snapshot: forfait, alquiler, clase_particular, etc.
  moduleType  String?  // "catalog" | "rental" | "hotel" | "spa" | "instructor" — derived from category, drives cascade logic
  quantity    Int      @default(1)
  unitPrice   Float
  discount    Float    @default(0) // percentage 0-100
  totalPrice  Float

  // Per-product dates and persons
  startDate       DateTime?
  endDate         DateTime?
  numDays         Int?
  numPersons      Int?
  ageDetails      Json?     // [{age: 8, type: "niño"}, {age: 35, type: "adulto"}]

  // Ski product variables
  station         String?
  modalidad       String?   // "alpino" | "snow"
  nivel           String?   // "A" | "A+" | "B" | "B+" | "C" | "D"
  sector          String?   // "Baqueira" | "Beret" | "Formigal" etc.
  idioma          String?   // "español" | "inglés" | "francés"
  horario         String?   // "10:00" | "13:00"
  puntoEncuentro  String?   // Meeting point

  // Equipment/rental
  tipoCliente     String?   // "niño" | "adulto" | "baby" | "senior"
  gama            String?   // "media" | "alta"
  casco           Boolean?  // Helmet included
  tipoActividad   String?   // "esquí" | "snow"
  tallaBotas      String?   // Boot size (filled post-purchase)
  alturaPeso      String?   // Height/weight (filled post-purchase)
  dni             String?   // DNI (for accommodation/rental)

  // Accommodation
  regimen           String?   // "solo_alojamiento" | "desayuno" | "media_pension" | "pension_completa"
  alojamientoNombre String?   // Accommodation name

  // Insurance & extras
  seguroIncluido  Boolean?  // Insurance included (forfait)
  notes           String?

  createdAt   DateTime @default(now())

  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@index([quoteId])
}

// ==================== TASKS (auto-generated on payment) ====================
model Task {
  id            String    @id @default(cuid())
  tenantId      String
  quoteId       String
  quoteItemId   String?
  type          String    // "request_dni" | "request_sizes" | "validate_level" | "offer_insurance" | "send_location" | "check_dni" | "prepare_material"
  title         String
  description   String?
  status        String    @default("pending") // "pending" | "completed"
  dueDate       DateTime?
  assignedTo    String?   // User ID
  completedAt   DateTime?
  completedBy   String?   // User ID who completed
  createdAt     DateTime  @default(now())

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteItem     QuoteItem? @relation(fields: [quoteItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([quoteId])
  @@index([tenantId, dueDate])
}

// ==================== RESERVATIONS ====================
model Reservation {
  id              String    @id @default(cuid())
  tenantId        String
  number          String?   // Sequential "RES-2026-0001" via generateDocumentNumber()
  ghlContactId    String?
  quoteId         String?

  // Client
  clientName      String
  clientPhone     String
  clientEmail     String
  couponCode      String?

  // Booking
  source          String    // "groupon" | "caja" | "web" | "presupuesto"
  station         String
  activityDate    DateTime
  schedule        String
  language        String    @default("es")

  // Participants (for group bookings)
  participants    Json?     // array of {name, type, service, level, material}

  // Services (for individual bookings)
  services        Json?     // array of {type, quantity, modality?, level?, days?}

  // Pricing
  totalPrice      Float     @default(0)
  discount        Float     @default(0)
  paymentMethod   String?
  paymentRef      String?

  // Status
  status          String    @default("pendiente") // pendiente, confirmada, sin_disponibilidad, cancelada

  // Notes
  notes           String?
  internalNotes   String?

  // Notification tracking
  emailSentAt     DateTime?
  whatsappSentAt  DateTime?
  notificationType String?  // "confirmacion" | "sin_disponibilidad"

  // Voucher tracking (Groupon)
  voucherImageUrl     String?
  voucherSecurityCode String?
  voucherCouponCode   String?
  voucherProduct      String?
  voucherPricePaid    Float?
  voucherExpiry       DateTime?
  voucherRedeemedAt   DateTime?
  voucherRedeemed     Boolean   @default(false)

  // Calendar
  calendarFileUrl String?
  qrCodeUrl       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote               Quote?              @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  activityBookings    ActivityBooking[]
  rentalOrders        RentalOrder[]
  structuredParticipants Participant[]
  operationalUnits    OperationalUnit[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
  @@index([tenantId, activityDate])
  @@index([tenantId, createdAt])
}

// ==================== STATION CAPACITY ====================
model StationCapacity {
  id          String   @id @default(cuid())
  tenantId    String
  station     String
  date        DateTime
  serviceType String   // "cursillo_adulto" | "cursillo_infantil" | "clase_particular"
  maxCapacity Int
  booked      Int      @default(0)

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, station, date, serviceType])
  @@index([tenantId, station])
}

// ==================== GROUPON PRODUCT MAPPING ====================
model GrouponProductMapping {
  id              String   @id @default(cuid())
  tenantId        String
  grouponDesc     String   // Groupon product description pattern
  pattern         String   // Regex pattern to match
  services        Json     // Array of {type, days, quantity, noHelmet?}
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ==================== WEBHOOK LOG ====================
model WebhookLog {
  id          String    @id @default(cuid())
  tenantId    String?
  event       String    // GHL event type
  payload     Json      // Raw webhook payload
  status      String    @default("received") // received, processed, failed
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, event])
  @@index([createdAt])
}

// ==================== GHL CACHE TABLES ====================

model CachedContact {
  id           String    @id // GHL contact ID
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  name         String?
  email        String?
  phone        String?
  tags         Json?     // string array
  customFields Json?     // key-value pairs
  source       String?
  dateAdded    DateTime?
  lastActivity DateTime?
  dnd          Boolean   @default(false)
  raw          Json?     // full GHL response
  cachedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model CachedConversation {
  id              String    @id // GHL conversation ID
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId       String
  contactName     String?
  contactPhone    String?
  contactEmail    String?
