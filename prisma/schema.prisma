// ==================== BOOKING/OPERATIONS ====================

model Client {
  id               String    @id @default(cuid())
  tenantId         String
  email            String?
  phone            String?
  name             String
  birthDate        DateTime?
  address          String?
  notes            String?
  cumulativeSpend  Float     @default(0)
  lifetimeValue    Float     @default(0)
  conversionSource String?
  acquiredAt       DateTime  @default(now())
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  // Ski-specific profile
  skiLevel         String?   // principiante | intermedio | avanzado | experto
  preferredStation String?
  bootSize         String?   // EU sizing 36-48
  height           Int?      // cm
  weight           Int?      // kg
  helmetSize       String?   // S | M | L | XL
  language         String?   // es | en | fr | de | pt
  dni              String?

  // Lifetime metrics (kept in sync via reservations/quotes auto-link)
  totalSpent       Int       @default(0) // cents
  visitCount       Int       @default(0)
  lastVisit        DateTime?

  // Fiscal address (PORT-09 enrichment) — separate from `address` (street/freeform)
  nif              String?  // CIF/NIF — distinct from `dni` (DNI is personal, NIF often B2B)
  city             String?
  postalCode       String?
  country          String?

  // CRM tags + conversion flag (set true once first reservation/booking lands)
  tags             Json     @default("[]")
  isConverted      Boolean  @default(false)

  tenant             Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  restaurantBookings RestaurantBooking[]
  invoices           Invoice[]
  tpvSales           TpvSale[]

  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, name])
  @@index([tenantId, skiLevel])
  @@index([tenantId, preferredStation])
}

model ActivityBooking {
  id               String   @id @default(cuid())
  tenantId         String
  reservationId    String
  activityDate     DateTime
  status           String   @default("scheduled") // "scheduled" | "pending" | "confirmed" | "cancelled"
  operationalNotes String?
  arrivedClient    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation      @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  monitors    BookingMonitor[]
  instructorAssignments InstructorAssignment[]

  @@index([tenantId, activityDate])
  @@index([tenantId, reservationId])
}

model BookingMonitor {
  id           String   @id @default(cuid())
  tenantId     String
  bookingId    String
  userId       String
  instructorId String?
  assignedAt   DateTime @default(now())

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  booking    ActivityBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  instructor Instructor?     @relation(fields: [instructorId], references: [id], onDelete: SetNull)

  @@unique([tenantId, bookingId, userId])
  @@index([tenantId])
}

model DailyOrder {
  id          String   @id @default(cuid())
