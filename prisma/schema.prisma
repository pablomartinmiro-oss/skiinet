// ==================== CMS: HOME MODULES ====================

model HomeModuleItem {
  id        String   @id @default(cuid())
  tenantId  String
  moduleKey String   // "featured" | "popular" | "seasonal"
  productId String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, moduleKey])
}

// ==================== TICKETING & PLATFORMS ====================

model ExternalPlatform {
  id                   String   @id @default(cuid())
  tenantId             String
  name                 String   // "Groupon" | "Smartbox" | etc.
  type                 String   @default("coupon") // "coupon" | "affiliate"
  commissionPercentage Float    @default(0)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  tenant      Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    PlatformProduct[]
  redemptions CouponRedemption[]

  @@index([tenantId])
}

model PlatformProduct {
  id          String   @id @default(cuid())
  tenantId    String
  platformId  String
  productId   String
  externalId  String?
  externalUrl String?
  status      String   @default("active") // "active" | "paused" | "removed"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform ExternalPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  product  Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([tenantId, platformId, productId])
  @@index([tenantId, platformId])
}

model CouponRedemption {
  id              String    @id @default(cuid())
  tenantId        String
  code            String
  email           String?
  phone           String?
  status          String    @default("received") // "received" | "pendiente" | "confirmado" | "completado" | "cancelado" | legacy "pending" | "reservation_generated"
  financialStatus String    @default("pending") // "pending" | "redeemed" | "incident"
  ocrExtraction   Json?     // { code, securityCode, customerName, confidence }
  reservationId   String?
  redeemedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Ski-specific enrichment
  customerName    String?
  platformId      String?
  productId       String?
  skiLevel        String?   // "principiante" | "intermedio" | "avanzado" | "experto"
  bootSize        String?
  height          Int?      // cm
  numPeople       Int       @default(1)
  preferredDate   DateTime?
  notes           String?

  tenant   Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  platform ExternalPlatform? @relation(fields: [platformId], references: [id], onDelete: SetNull)
  product  Product?          @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([tenantId, code])
  @@index([tenantId, status])
  @@index([tenantId, platformId])
  @@index([tenantId, redeemedAt])
}

model CouponEmailConfig {
  id           String   @id @default(cuid())
  tenantId     String
  templateId   String
  eventTrigger String   // "redemption_received" | "reservation_created" | etc.
  enabled      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, templateId, eventTrigger])
  @@index([tenantId])
}

// ==================== REVIEWS ====================

model Review {
  id              String    @id @default(cuid())
  tenantId        String
  entityType      String    // "experience" | "hotel" | "spa" | "restaurant"
  entityId        String
  rating          Int       // 1-5
  authorName      String
  authorEmail     String?
  title           String?
  body            String    @db.Text
  stayDate        DateTime?
  status          String    @default("pending") // "pending" | "approved" | "rejected"
  reply           String?   @db.Text
  verifiedBooking Boolean   @default(false)  // True if authorEmail matches a Reservation
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@index([tenantId, verifiedBooking])
}

// ==================== PACKS ====================

model LegoPack {
  id          String   @id @default(cuid())
  tenantId    String
  title       String
  slug        String
  categoryId  String?
  price       Float    @default(0)
  images      Json     @default("[]")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lines  LegoPackLine[]

  @@unique([tenantId, slug])
  @@index([tenantId, isActive])
}

model LegoPackLine {
  id               String   @id @default(cuid())
  tenantId         String
  packId           String
  productId        String?
  roomTypeId       String?
  treatmentId      String?
  quantity         Int      @default(1)
  isRequired       Boolean  @default(true)
  isOptional       Boolean  @default(false)
  isClientEditable Boolean  @default(false)
  overridePrice    Float?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pack   LegoPack @relation(fields: [packId], references: [id], onDelete: Cascade)

  @@index([tenantId, packId])
}

// ==================== PAYROLL ====================

model PayrollRecord {
  id          String    @id @default(cuid())
  tenantId    String
  userId      String
  year        Int
  month       Int       // 1-12
  baseSalary  Float     @default(0)
  totalExtras Float     @default(0)
  totalAmount Float     @default(0)
  status      String    @default("draft") // draft, approved, paid
  paidAt      DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  extras PayrollExtra[]

  @@unique([tenantId, userId, year, month])
  @@index([tenantId, year, month])
}

model PayrollExtra {
  id        String   @id @default(cuid())
  tenantId  String
  payrollId String
  concept   String
  type      String   @default("bonus") // bonus, deduction, commission, overtime
  amount    Float
  createdAt DateTime @default(now())

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payroll PayrollRecord @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([tenantId, payrollId])
}

// ==================== INSTRUCTORS ====================

model Instructor {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String    @unique

  // Certification (TD System - Spain)
  tdLevel         String    // "TD1" | "TD2" | "TD3"
  certExpiry      DateTime?
  certNumber      String?

  // Skills
  disciplines     Json      @default("[]") // ["esqui", "snow", "telemark", "freestyle"]
  specialties     Json      @default("[]") // ["adaptive", "competition", "children"]
  languages       Json      @default("[]") // ["es", "en", "fr", "de", "pt"]
  maxLevel        String?   // "A" | "B" | "C" | "D" — constrained by TD

  // Compensation
  hourlyRate      Float     @default(0)
  perStudentBonus Float     @default(0)
  contractType    String    @default("fijo_discontinuo") // fijo_discontinuo | temporal | autonomo

  // Station assignment
  station         String

  // Season / status
  seasonStart     DateTime?
  seasonEnd       DateTime?
  isActive        Boolean   @default(true)
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  availability    InstructorAvailability[]
  timeEntries     InstructorTimeEntry[]
  assignments     InstructorAssignment[]
  bookingMonitors BookingMonitor[]
  groupCells           GroupCell[]
  incidents            Incident[]
  freeDayRequests      FreeDayRequest[]
  disciplinaryRecords  DisciplinaryRecord[]

  @@unique([tenantId, userId])
  @@index([tenantId, isActive])
  @@index([tenantId, station])
}

model InstructorAvailability {
  id           String   @id @default(cuid())
  tenantId     String
  instructorId String
  dayOfWeek    Int      // 0=Sun, 6=Sat
  startTime    String   // "09:00" (HH:mm)
  endTime      String   // "17:00" (HH:mm)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, instructorId, dayOfWeek])
  @@index([tenantId, instructorId])
}

model InstructorTimeEntry {
  id           String    @id @default(cuid())
  tenantId     String
  instructorId String
  date         DateTime  // Working day (date only)

  // Clock in/out
  clockIn      DateTime
  clockOut     DateTime?

  // Calculated (set on clockOut)
  totalMinutes Int       @default(0)
  breakMinutes Int       @default(0)
  netMinutes   Int       @default(0) // totalMinutes - breakMinutes

  // Legal compliance (RD-ley 8/2019)
  source       String    @default("manual") // "manual" | "mobile" | "kiosk"
  ipAddress    String?
  geoLat       Float?    // clock-in geolocation
  geoLon       Float?
  clockOutLat  Float?    // clock-out geolocation
  clockOutLon  Float?

  // Immutability: locked entries cannot be edited
  lockedAt     DateTime?
  lockedBy     String?

  // Correction chain (instead of editing locked entries)
  correctionOf     String?
  correctionReason String?

  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([tenantId, instructorId, date])
  @@index([tenantId, date])
}

model InstructorAssignment {
  id              String    @id @default(cuid())
  tenantId        String
  instructorId    String
  bookingId       String

  // Lesson details
  lessonType      String    // "group" | "private" | "adaptive"
  studentCount    Int       @default(1)
  scheduledStart  String    // "10:00" (HH:mm)
  scheduledEnd    String    // "13:00" (HH:mm)

  // Rate snapshot (frozen at assignment time)
  hourlyRate      Float     @default(0)
  bonusPerStudent Float     @default(0)
  surcharge       Float     @default(0)
  surchargeReason String?

  // Status
  status          String    @default("assigned") // assigned | in_progress | completed | cancelled | no_show
  completedAt     DateTime?
  notes           String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor Instructor      @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  booking    ActivityBooking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([tenantId, instructorId, bookingId])
  @@index([tenantId, bookingId])
  @@index([tenantId, instructorId, status])
}

// ==================== RENTAL ====================

model RentalInventory {
  id                String    @id @default(cuid())
  tenantId          String
  stationSlug       String
  equipmentType     String    // SKI | BOOT | POLE | HELMET | SNOWBOARD | SNOWBOARD_BOOT
  size              String    // Flexible: "42" (EU shoe), "170" (ski cm), "M" (helmet)
  qualityTier       String    // "media" | "alta"
  totalQuantity     Int       @default(0)
  availableQuantity Int       @default(0)
  minStockAlert     Int       @default(5)
  condition         String    @default("bueno") // bueno | dañado | mantenimiento | baja
  lastMaintenanceAt DateTime?
  notes             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, stationSlug, equipmentType, size, qualityTier])
  @@index([tenantId, stationSlug])
  @@index([tenantId, equipmentType])
  @@index([tenantId, condition])
}

model RentalOrder {
  id              String    @id @default(cuid())
  tenantId        String
  reservationId   String?
  clientName      String
  clientEmail     String?
  clientPhone     String?
  stationSlug     String
  pickupDate      DateTime
  returnDate      DateTime
  status          String    @default("RESERVED") // RESERVED | PREPARED | PICKED_UP | RETURNED | INSPECTED | CANCELLED

  // Timestamps
  preparedAt      DateTime?
  preparedBy      String?
  pickedUpAt      DateTime?
  pickedUpBy      String?
  returnedAt      DateTime?
  returnedBy      String?
  inspectedAt     DateTime?
  inspectedBy     String?
  cancelledAt     DateTime?

  // Pricing
  totalPrice      Float     @default(0)
  discount        Float     @default(0)
  paymentStatus   String    @default("pending") // pending | paid | partial | refunded

  // Deposit + signature
  depositCents    Int       @default(0)
  depositReturned Boolean   @default(false)
  signatureUrl    String?
  damageNotes     String?

  notes           String?
  internalNotes   String?
  createdBy       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation Reservation?      @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  items       RentalOrderItem[]

  @@index([tenantId, status])
  @@index([tenantId, pickupDate])
  @@index([tenantId, returnDate])
  @@index([tenantId, stationSlug])
  @@index([tenantId, reservationId])
}

model RentalOrderItem {
  id                String    @id @default(cuid())
  rentalOrderId     String
  participantName   String
  equipmentType     String    // SKI | BOOT | POLE | HELMET | SNOWBOARD | SNOWBOARD_BOOT
  size              String?   // Assigned at pickup
  qualityTier       String    // "media" | "alta"
  dinSetting        Float?    // ISO 11088 DIN value for ski bindings
  itemStatus        String    @default("RESERVED") // RESERVED | ASSIGNED | PICKED_UP | RETURNED | DAMAGED

  // Return inspection
  conditionOnReturn String?   // "OK" | "NEEDS_SERVICE" | "DAMAGED"
  damageNotes       String?

  // Pricing
  unitPrice         Float     @default(0)

  // Phase 2: individual item tracking
  serialNumber      String?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  rentalOrder RentalOrder @relation(fields: [rentalOrderId], references: [id], onDelete: Cascade)

  @@index([rentalOrderId])
  @@index([rentalOrderId, equipmentType])
}

model CustomerSizingProfile {
  id                  String    @id @default(cuid())
  tenantId            String
  clientEmail         String
  clientName          String
  clientPhone         String?
  height              Float?    // cm
  weight              Float?    // kg
  shoeSize            String?   // EU size: "42", "38.5"
  age                 Int?
  abilityLevel        String?   // beginner | intermediate | advanced | expert
  bootSoleLength      Float?    // mm (for DIN calculation)
  preferredDinSetting Float?
  notes               String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientEmail])
  @@index([tenantId, clientName])
  @@index([tenantId, clientPhone])
}

// ==================== PLANNING ENGINE ====================

model Participant {
  id              String    @id @default(cuid())
  tenantId        String
  reservationId   String?   // null for walk-in / manual participants
  firstName       String
  lastName        String?
  birthDate       DateTime?
  age             Int?
  ageBracket      String?   // "baby" | "infantil" | "adolescente" | "juvenil" | "adulto"
  discipline      String    // "esqui" | "snow" | "telemark" | "freestyle"
  level           String    // "A" | "B" | "C" | "D"
  language        String    @default("es")
  specialNeeds    String?
  relationship    String?   // "titular" | "hijo" | "pareja" | "amigo"
  phone           String?   // contact phone for walk-in participants
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservation     Reservation?    @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  operationalUnits OperationalUnit[]
  checkIns        ClassCheckIn[]

  @@index([tenantId, reservationId])
}

model OperationalUnit {
  id              String    @id @default(cuid())
  tenantId        String
  participantId   String
  reservationId   String?   // null for walk-in / manual participants
  productId       String?
  activityDate    DateTime
  planningMode    String    // "fixed_slot" | "dynamic_grouping"
  status          String    @default("pending") // pending | grouped | assigned | cancelled
  groupCellId     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participant     Participant  @relation(fields: [participantId], references: [id], onDelete: Cascade)
  reservation     Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product         Product?     @relation(fields: [productId], references: [id], onDelete: SetNull)
  groupCell       GroupCell?   @relation(fields: [groupCellId], references: [id], onDelete: SetNull)

  @@index([tenantId, activityDate, status])
  @@index([tenantId, reservationId])
}

model GroupCell {
  id              String    @id @default(cuid())
  tenantId        String
  activityDate    DateTime
  station         String
  timeSlotStart   String    // "10:00" (HH:mm)
  timeSlotEnd     String    // "13:00" (HH:mm)
  discipline      String    // "esqui" | "snow"
  level           String    // "A" | "B" | "C" | "D"
  ageBracket      String?   // "baby" | "infantil" | "adolescente" | "adulto"
  language        String    @default("es")
  maxParticipants Int       @default(10)
  instructorId    String?
  meetingPointId  String?
  status          String    @default("draft") // draft | confirmed | in_progress | completed | cancelled
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor      Instructor?       @relation(fields: [instructorId], references: [id], onDelete: SetNull)
  meetingPoint    Location?         @relation(fields: [meetingPointId], references: [id], onDelete: SetNull)
  units           OperationalUnit[]
  checkIns        ClassCheckIn[]
  incidents       Incident[]

  @@index([tenantId, activityDate, station])
  @@index([tenantId, instructorId, activityDate])
}

model ClassCheckIn {
  id              String    @id @default(cuid())
  tenantId        String
  groupCellId     String
  participantId   String
  status          String    @default("pending") // pending | present | absent | no_show
  checkedAt       DateTime?
  checkedBy       String?
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupCell       GroupCell   @relation(fields: [groupCellId], references: [id], onDelete: Cascade)
  participant     Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, groupCellId, participantId])
  @@index([tenantId, groupCellId])
}

model Incident {
  id              String    @id @default(cuid())
  tenantId        String
  groupCellId     String
  instructorId    String
  participantId   String?
  type            String    // "level_mismatch" | "age_mismatch" | "danger" | "medical" | "general"
  severity        String    @default("normal") // "normal" | "urgent"
  description     String
  resolved        Boolean   @default(false)
  resolvedAt      DateTime?
  resolvedBy      String?
  resolvedNotes   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  groupCell       GroupCell  @relation(fields: [groupCellId], references: [id], onDelete: Cascade)
  instructor      Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([tenantId, groupCellId])
  @@index([tenantId, instructorId])
  @@index([tenantId, resolved])
}

model FreeDayRequest {
  id              String    @id @default(cuid())
  tenantId        String
  instructorId    String
  requestDate     DateTime
  reason          String?
  status          String    @default("pending") // pending | approved | rejected
  reviewedBy      String?
  reviewedAt      DateTime?
  reviewNotes     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor      Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([tenantId, instructorId, requestDate])
  @@index([tenantId, status])
  @@index([tenantId, instructorId])
}

model Diploma {
  id              String    @id @default(cuid())
  tenantId        String
  participantId   String
  instructorId    String
  groupCellId     String?
  level           String    // "A" | "B" | "C" | "D"
  discipline      String    // "esqui" | "snow"
  station         String
  issuedAt        DateTime  @default(now())
  participantName String
  instructorName  String
  notes           String?
  createdAt       DateTime  @default(now())

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, participantId])
  @@index([tenantId, instructorId])
}

model DisciplinaryRecord {
  id              String    @id @default(cuid())
  tenantId        String
  instructorId    String
  type            String    // "warning" | "reprimand" | "suspension"
  reason          String
  issuedBy        String
  issuedAt        DateTime  @default(now())
  expiresAt       DateTime?
  acknowledged    Boolean   @default(false)
  acknowledgedAt  DateTime?
  notes           String?
  createdAt       DateTime  @default(now())

  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  instructor  Instructor @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([tenantId, instructorId])
}

model NotificationTemplate {
  id          String    @id @default(cuid())
  tenantId    String
  trigger     String    // "reservation_confirmed" | "class_reminder" | "schedule_change" | "daily_summary"
  channel     String    // "whatsapp" | "email" | "push"
  subject     String?
  body        String    // Template with {{variables}}
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, trigger, channel])
  @@index([tenantId])
}

model NotificationLog {
  id          String    @id @default(cuid())
  tenantId    String
  templateId  String?
  channel     String    // "whatsapp" | "email" | "push"
  recipient   String    // phone or email
  subject     String?
  body        String
  status      String    @default("sent") // "sent" | "delivered" | "failed"
  sentAt      DateTime  @default(now())
  error       String?

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sentAt])
}

// ==================== DOCUMENT NUMBERING ====================
model DocumentCounter {
  id            String   @id @default(cuid())
  tenantId      String
  documentType  String   // "invoice" | "quote" | "reservation" | "tpv" | "coupon" | "settlement" | "cancellation" | "credit_note"
  year          Int
  currentNumber Int      @default(0)
  prefix        String   // "FAC-" | "PRE-" | "RES-" | "TPV-" | "CUP-" | "LIQ-" | "ANU-" | "ABN-"
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, documentType, year])
  @@index([tenantId])
}

model DocumentNumberLog {
  id             String   @id @default(cuid())
  tenantId       String
  documentType   String
  documentNumber String   // "FAC-2026-0001"
  year           Int
  sequence       Int
  generatedAt    DateTime @default(now())
  generatedBy    String?  // userId or "system"
  context        String?  // "auto" | "manual" | "admin:resetCounter"

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, documentType])
  @@index([tenantId, generatedAt])
}

// ==================== EMAIL TEMPLATES ====================
model EmailTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  templateKey     String   // "reservation_confirm" | "quote_send" | "payment_failed" | etc.
  name            String
  description     String?
  category        String?  // "reservations" | "quotes" | "cancellations" | "tpv" | "crm"
  recipient       String?  // "client" | "admin" | "both"
  subject         String
  headerImageUrl  String?
  headerTitle     String?
  headerSubtitle  String?
  bodyHtml        String   @db.Text
  footerText      String?
  ctaLabel        String?
  ctaUrl          String?
  variables       String?  // JSON string of available variables
  isCustom        Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, templateKey])
  @@index([tenantId])
}

// ==================== PDF TEMPLATES ====================
model PdfTemplate {
  id              String   @id @default(cuid())
  tenantId        String
  templateKey     String   // "quote" | "invoice" | "settlement" | "ticket"
  name            String
  description     String?
  category        String?
  logoUrl         String?
  headerColor     String?  @default("#E87B5A")
  accentColor     String?  @default("#5B8C6D")
  companyName     String?
  companyAddress  String?
  companyPhone    String?
  companyEmail    String?
  companyNif      String?
  footerText      String?
  legalText       String?
  showLogo        Boolean  @default(true)
  showWatermark   Boolean  @default(false)
  bodyHtml        String   @db.Text
  variables       String?
  isCustom        Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, templateKey])
  @@index([tenantId])
}

// ==================== LEADS ====================
model Lead {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Contact info
  name        String
  email       String?
  phone       String?
  company     String?

  // Lead management
  source        String   @default("manual") // manual, web, import, storefront, referral, contact_form, storefront_budget, ghl_survey, ghl_webhook
  status        String   @default("nuevo")  // nuevo, contactado, calificado, convertido, perdido
  priority      String   @default("media")  // baja, media, alta, urgente
  score         Int      @default(0)        // 0-100 rule-based scoring
  assignedTo    String?
  assignedUser  User?    @relation(fields: [assignedTo], references: [id])

  // Pipeline
  pipelineStage String   @default("nuevo")

  // Request data (from forms/surveys)
  experienceId     String?      // Product/Experience the lead is interested in
  locationId       String?
  preferredDate    DateTime?
  numberOfPersons  Int?
  numberOfAdults   Int?
  numberOfChildren Int?
  budget           Float?
  message          String?
  selectedCategory String?
  selectedProduct  String?
  activitiesJson   Json?        // Raw survey services preferences for auto-quote regeneration

  // Details
  notes         String?
  internalNotes Json   @default("[]")  // [{ text, authorId, authorName, createdAt }] — admin notes thread
  tags          String[] @default([])
  customFields  Json?    @default("{}")

  // Tracking
  lastContactedAt DateTime?  // Updated on intake re-delivery (system)
  lastContactAt   DateTime?  // Updated when admin makes manual contact
  seenAt          DateTime?  // First time an admin viewed the lead
  convertedAt     DateTime?
  lostReason      String?

  // Conversion
  quoteId       String?  // Denormalised pointer to the lead's primary Quote
  quotes        Quote[]  @relation("LeadQuotes")  // Inverse — one lead may have N quote revisions

  // GHL integration
  ghlContactId      String?  // Idempotency key for webhook re-deliveries
  ghlOpportunityId  String?  // Linked GHL opportunity once converted
  opportunityStatus String?  // nueva | enviada | ganada | perdida

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, ghlContactId])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, score])
  @@index([tenantId, priority])
}

// ==================== CRM ACTIVITY LOG ====================
// Audit trail for all CRM actions across leads, quotes, reservations,
// invoices and payments. Append-only. Used to render entity timelines.
model CrmActivityLog {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  entityType String   // "lead" | "quote" | "reservation" | "invoice" | "payment"
  entityId   String

  action     String   // "created" | "updated" | "status_changed" | "email_sent" | "payment_received" | "payment_failed" | "note_added" | "assigned" | "converted" | "lost"
  actorId    String?  // userId; null for system actions (webhooks, cron)
  actorName  String?
  details    Json?    // { oldStatus, newStatus, note, amount, ... }

  createdAt  DateTime @default(now())

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

// ==================== PENDING PAYMENTS ====================
// Tracks money owed to the tenant: bank transfers awaiting confirmation,
// outstanding invoice balances, etc. Surfaces in admin dashboard with
// reminder cadence.
model PendingPayment {
  id              String    @id @default(cuid())
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  quoteId          String?
  reservationId    String?

  clientName       String
  clientEmail      String?
  clientPhone      String?
  productName      String?

  amountCents      Int
  dueDate          DateTime?
  reason           String?

  status           String    @default("pending") // "pending" | "reminded" | "paid" | "cancelled"
  paymentMethod    String?
  paymentNote      String?
  transferProofUrl String?
  paidAt           DateTime?
  reminderSentAt   DateTime?
  reminderCount    Int       @default(0)

  createdBy        String?   // userId who registered the pending payment
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([tenantId, status])
  @@index([tenantId, dueDate])
}

// ==================== LEGO PACK SNAPSHOTS ====================
// Frozen pricing snapshot taken when a pack is sold. Decouples future
// pack edits from already-issued documents.
model LegoPackSnapshot {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  packId        String
  packTitle     String
  packSlug      String?

  operationType String   // "tpv_sale" | "reservation" | "quote"
  operationId   String

  pricedAt      DateTime @default(now())
  totalPrice    Float
  linesJson     Json     // Array of { lineId, productId?, quantity, unitPrice, totalPrice, label }
  currency      String   @default("EUR")

  createdAt     DateTime @default(now())

  @@index([tenantId, packId])
  @@index([tenantId, operationType, operationId])
}
