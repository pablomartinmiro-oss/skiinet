// ==================== SUPPLIERS ====================

model Supplier {
  id                       String   @id @default(cuid())
  tenantId                 String
  fiscalName               String
  commercialName           String?
  nif                      String
  iban                     String?
  email                    String?
  phone                    String?
  fiscalAddress            String?
  contactPerson            String?
  adminEmail               String?
  commissionPercentage     Float    @default(0)
  commissionType           String   @default("percentage") // "percentage" | "fixed" | "margin" | "hybrid"
  fixedCostPerUnit         Float?
  marginPercentage         Float?
  paymentMethod            String   @default("transfer") // "transfer" | "card"
  settlementFrequency      String   @default("monthly") // "biweekly" | "monthly" | "quarterly"
  settlementDayOfMonth     Int      @default(1)  // Day of month (1-28) when autoGenerateSettlements fires
  autoGenerateSettlements  Boolean  @default(false)
  status                   String   @default("active") // "active" | "inactive" | "blocked"
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  tenant      Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settlements SupplierSettlement[]
  expenses    Expense[]
  products    Product[]

  @@unique([tenantId, nif])
  @@index([tenantId, status])
}

model SupplierSettlement {
  id               String    @id @default(cuid())
  tenantId         String
  supplierId       String
  number           String    // "LIQ-2026-0001" — unique per tenant
  startDate        DateTime
  endDate          DateTime
  status           String    @default("draft") // "draft" | "sent" | "paid"
  grossAmount      Float     @default(0)
  commissionAmount Float     @default(0)
  netAmount        Float     @default(0)
  pdfUrl           String?
  pdfKey           String?   // S3 key (PORT-10)
  internalNotes    String?
  sentAt           DateTime?
  paidAt           DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier  Supplier              @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  lines     SettlementLine[]
  documents SettlementDocument[]
  statusLog SettlementStatusLog[]

  @@unique([tenantId, number])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
}

model SettlementLine {
  id                   String   @id @default(cuid())
  tenantId             String
  settlementId         String
  serviceType          String   // "activity" | "hotel" | "restaurant" | "spa"
  productId            String?
  serviceDate          DateTime
  paxCount             Int      @default(1)
  saleAmount           Float
  commissionPercentage Float
  commissionAmount     Float
  reservationId        String?
  invoiceId            String?
  createdAt            DateTime @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settlement SupplierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([tenantId, settlementId])
}

model SettlementDocument {
  id           String   @id @default(cuid())
  tenantId     String
  settlementId String
  url          String
  uploadedAt   DateTime @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settlement SupplierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([tenantId, settlementId])
}

model SettlementStatusLog {
  id             String   @id @default(cuid())
  tenantId       String
  settlementId   String
  previousStatus String
  newStatus      String
  actorId        String
  reason         String?
  timestamp      DateTime @default(now())

  tenant     Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  settlement SupplierSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([tenantId, settlementId])
}

// ==================== REAV ====================

model ReavExpedient {
  id               String   @id @default(cuid())
  tenantId         String
  expedientNumber  String?  // Sequential "REAV-2026-0001" via generateDocumentNumber("cancellation"/"settlement"-style)
  invoiceId        String
  operationType    String   @default("standard")
  costPercentage   Float    @default(0)
  marginPercentage Float    @default(0)
  marginAmount     Float    @default(0)
  taxableBase      Float    @default(0)
  vat              Float    @default(0)
  fiscalStatus     String   @default("borrador")  // borrador | calculado | declarado | cerrado | anulado
  operativeStatus  String   @default("pendiente") // pendiente | en_curso | completado | cancelado
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice   Invoice        @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  costs     ReavCost[]
  documents ReavDocument[]

  @@unique([tenantId, expedientNumber])
  @@index([tenantId, invoiceId])
  @@index([tenantId, fiscalStatus])
  @@index([tenantId, operativeStatus])
}

model ReavCost {
  id           String   @id @default(cuid())
  tenantId     String
  expedientId  String
  description  String
  cost         Float
  notes        String?
  createdAt    DateTime @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expedient ReavExpedient @relation(fields: [expedientId], references: [id], onDelete: Cascade)

  @@index([tenantId, expedientId])
}

model ReavDocument {
  id           String   @id @default(cuid())
  tenantId     String
  expedientId  String
  type         String   // "client" | "provider"
  url          String
  uploadedAt   DateTime @default(now())

  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expedient ReavExpedient @relation(fields: [expedientId], references: [id], onDelete: Cascade)

  @@index([tenantId, expedientId])
}

// ==================== TPV ====================

model CashRegister {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  location  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions CashSession[]

  @@index([tenantId])
}

model CashSession {
  id            String    @id @default(cuid())
  tenantId      String
  registerId    String
  openedById    String
  openingAmount Float     @default(0)
  closingAmount Float?
  totalCash     Float?
  totalCard     Float?
  totalBizum    Float?
  discrepancy   Float?
  status        String    @default("open") // "open" | "closed"
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  register  CashRegister   @relation(fields: [registerId], references: [id], onDelete: Cascade)
  openedBy  User           @relation(fields: [openedById], references: [id], onDelete: Cascade)
  movements CashMovement[]
  sales     TpvSale[]

  @@index([tenantId, status])
  @@index([tenantId, registerId])
}

model CashMovement {
  id        String   @id @default(cuid())
  tenantId  String
  sessionId String
  type      String   // "in" | "out"
  amount    Float
  reason    String
  timestamp DateTime @default(now())

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantId, sessionId])
}

model TpvSale {
  id              String   @id @default(cuid())
  tenantId        String
  sessionId       String
  ticketNumber    String   // "TKT-2026-0001" — unique per tenant
  date            DateTime
  totalAmount     Float
  discountApplied Float?
  totalTax        Float    @default(0)
  paymentMethods  Json     @default("{}") // { cash: 0, card: 0, bizum: 0 }
  clientId        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant  Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session CashSession   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  client  Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items   TpvSaleItem[]

  @@unique([tenantId, ticketNumber])
  @@index([tenantId, date])
  @@index([tenantId, sessionId])
}

model TpvSaleItem {
  id             String   @id @default(cuid())
  tenantId       String
  saleId         String
  productId      String?
  description    String
  quantity       Int      @default(1)
  unitPrice      Float
  lineTotal      Float
  discountAmount Float?
  fiscalRegime   String   @default("general") // "general" | "reav"
  taxPerLine     Float    @default(0)
  createdAt      DateTime @default(now())

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale   TpvSale @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([tenantId, saleId])
}

// ==================== STOREFRONT & PROMOTIONS ====================

model DiscountCode {
  id             String    @id @default(cuid())
  tenantId       String
  code           String
  name           String?
  description    String?
  observations   String?
  type           String    @default("percentage") // "percentage" | "fixed"
  value          Float
  expirationDate DateTime?
  maxUses        Int       @default(0) // 0 = unlimited
  usedCount      Int       @default(0)
  isActive       Boolean   @default(true)
  origin         String    @default("manual") // "manual" | "voucher"
  compensationVoucherId String?  // Links back to CompensationVoucher when origin == "voucher"
  clientEmail    String?
  clientName     String?
  createdById    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  tenant Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uses   DiscountCodeUse[]

  @@unique([tenantId, code])
  @@index([tenantId, isActive])
  @@index([tenantId, origin])
  @@index([compensationVoucherId])
}

model DiscountCodeUse {
  id             String   @id @default(cuid())
  tenantId       String
  codeId         String
  originalAmount Float
  finalAmount    Float
  discountAmount Float
  channel        String   @default("online") // "tpv" | "online" | "crm" | "delegated"
  reservationId  String?
  saleId         String?
  appliedAt      DateTime @default(now())

  tenant Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code   DiscountCode @relation(fields: [codeId], references: [id], onDelete: Cascade)

  @@index([tenantId, codeId])
}

model CompensationVoucher {
  id                   String    @id @default(cuid())
  tenantId             String
  code                 String    // "BON-2026-XXXX"
  cancellationId       String?
  type                 String    @default("monetary") // "activity" | "monetary" | "service"
  value                Float
  expirationDate       DateTime?
  isUsed               Boolean   @default(false)
  linkedDiscountCodeId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  tenant       Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cancellation CancellationRequest? @relation("CancellationVouchers", fields: [cancellationId], references: [id], onDelete: SetNull)

  @@unique([tenantId, code])
  @@index([tenantId, isUsed])
}

// ==================== CANCELLATIONS ====================

model CancellationRequest {
  id                String    @id @default(cuid())
  tenantId          String
  reservationId     String?
  quoteId           String?
  reason            String?
  status            String    @default("recibida") // recibida, en_revision, pendiente_documentacion, pendiente_decision, resuelta, cerrada
  resolution        String?   // rejected, fully_accepted, partially_accepted
  operationalStatus String?
  financialStatus   String?   // devuelta_economicamente, pendiente_devolucion, bono_emitido
  refundAmount      Float?
  creditNoteNumber  String?   // ANU-YYYY-NNNN
  submissionDate    DateTime  @default(now())
  resolvedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  logs            CancellationLog[]
  vouchers        CompensationVoucher[] @relation("CancellationVouchers")

  @@index([tenantId, status])
  @@index([tenantId, reservationId])
}

model CancellationLog {
  id             String   @id @default(cuid())
  tenantId       String
  requestId      String
  previousStatus String
  newStatus      String
  actorId        String
  notes          String?
  timestamp      DateTime @default(now())

  tenant  Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  request CancellationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([tenantId, requestId])
}

// ==================== CMS ====================

model SiteSetting {
