  tenantId     String
  filename     String
  originalName String
  url          String
  fileKey      String?  // S3 key if uploaded, null if external URL
  mimeType     String
  size         Int?     // bytes, null if external URL
  type         String   @default("image") // "image" | "video" | "document"
  altText      String?
  uploadedBy   String?  // userId
