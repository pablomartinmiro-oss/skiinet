model CmsMenuItem {
  id        String   @id @default(cuid())
  tenantId  String
  label     String
  url       String
  position  String   @default("header") // "header" | "footer"
  parentId  String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   CmsMenuItem? @relation("CmsMenuParent", fields: [parentId], references: [id], onDelete: SetNull)
  children CmsMenuItem[] @relation("CmsMenuParent")

  @@index([tenantId, position])
