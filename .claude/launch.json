{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Next.js dev server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "Vitest watch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test:watch"],
      "port": 51204
    },
    {
      "name": "Prisma Studio",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["prisma", "studio"],
      "port": 5555
    },
    {
      "name": "Postgres (Homebrew, ya activo)",
      "runtimeExecutable": "brew",
      "runtimeArgs": ["services", "start", "postgresql@17"],
      "port": 5432
    },
    {
      "name": "Redis (Homebrew, ya activo)",
      "runtimeExecutable": "brew",
      "runtimeArgs": ["services", "start", "redis"],
      "port": 6379
    }
  ]
}
